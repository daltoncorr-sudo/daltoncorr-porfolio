\f1 \cf2 \cb3 \strokec2 \'a0property of\'a0{\field{\*\fldinst{HYPERLINK "https://developer.apple.com/documentation/WalletPasses/PassFields/AuxiliaryFields-data.dictionary"}}{\fldrslt 
\f3 \cf4 \cb3 \ul \ulc4 \strokec4 PassFields.AuxiliaryFields}}.\cb1 \
